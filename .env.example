# ------------------------------------------------------------------------------
# SADBMS — copy to .env and fill in real values
# ------------------------------------------------------------------------------

APP_NAME=SADBMS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sadbms
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
# Set true when serving over HTTPS (e.g. sadbms.tesnet.xyz)
SESSION_SECURE_COOKIE=false

FILESYSTEM_DISK=local
CACHE_STORE=database
QUEUE_CONNECTION=sync

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

ADMIN_REGISTRATION_EMAIL=reginaldtesla6@gmail.com

# ------------------------------------------------------------------------------
# Unused by SADBMS (Laravel defaults apply if omitted)
# ------------------------------------------------------------------------------
# APP_FAKER_LOCALE=en_US
# APP_MAINTENANCE_DRIVER=file
# PHP_CLI_SERVER_WORKERS=4
# BCRYPT_ROUNDS=12
# SESSION_ENCRYPT=false
# SESSION_DOMAIN=null
